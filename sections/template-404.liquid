<h1>{{ section.settings.title }}</h1>
<p>{{ section.settings.subtext }}</p>

{% schema %}
{
    "name": "Template 404",
    "settings": [
        {
            "type": "text",
            "id": "title",
            "label": "404 Title",
            "default": "404 - Page Not Found"
        },
        {
            "type": "text",
            "id": "subtext",
            "label": "404 Subtext",
            "default": "The page you are looking for doesn't exist or has been moved."
        } 
    ]
}
{% endschema %}