<div class="py-8">
  {% paginate blog.articles by section.settings.blogs_per_page %}
    <h1 class="text-3xl text-center font-bold mb-4">
      {{ blog.title }}
    </h1>
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {% for article in blog.articles %}
          <div class="w-full py-6 px-3">
            <div class="bg-white rounded-lg shadow-md overflow-hidden">
              {% if article.image != blank %}
                <img
                  src="{{ article.image | image_url: width: 800 }}"
                  srcset="
                    {{ article.image | image_url: width: 400 }} 400w,
                    {{ article.image | image_url: width: 800 }} 800w,
                    {{ article.image | image_url: width: 1200 }} 1200w
                  "
                  sizes="(min-width: 990px) 33vw, 100vw"
                  width="{{ article.image.width }}"
                  height="{{ article.image.height }}"
                  alt="{{ article.image.alt | escape }}"
                  loading="lazy"
                  class="w-full h-80 object-cover"
                >
              {% else %}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-80 object-cover bg-gray-100' }}
              {% endif %}
              <div class="p-4">
                <p class="text-gray-500 text-sm mb-2">{{ article.published_at | date: '%B %d, %Y' }}</p>
                <h1 class="text-xl font-bold my-4">{{ article.title }}</h1>
                {% if article.excerpt.size > 0 %}
                  <p>{{ article.excerpt | strip_html | truncatewords: 15 }}</p>
                {% else %}
                  <p>{{ article.content | strip_html | truncate: 150 }}</p>
                {% endif %}

                <a href="{{ article.url }}" class="text-blue-500 hover:text-blue-700 mt-4 inline-block">
                  {{- section.settings.read_more_text -}}
                </a>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
    <div class="max-w-6xl mx-auto mt-8">
      {% render 'pagination', pagination: paginate %}
    </div>
  {% endpaginate %}
</div>

{% schema %}
{
  "name": "Blog",
  "settings": [
    {
      "type": "range",
      "id": "blogs_per_page",
      "label": "Blogs per page",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 1
    },
    {
      "type": "text",
      "id": "read_more_text",
      "label": "Read More Text",
      "default": "Read more"
    }
  ]
}
{% endschema %}
